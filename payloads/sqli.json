    "uNiOn SeLeCt", "UNI%4FN SEL%45CT",
    "'%20OR%20'1'%3D'1", "' OR 1=1/*", "' OR ''='",
    "1'%20oR%20'1'%3D'1", "admin'/*", "') or ('1'='1",
    "0x27 OR 1=1--", "' OR 1 LIKE 1--"
  ]
}
